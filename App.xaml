<Application x:Class="DesktopTaskWidget.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F7FAFC" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D6DEE8" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1B2733" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#687382" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2E7D6F" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B33A3A" />
    </Application.Resources>
</Application>

