<Window x:Class="DesktopTaskWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Desktop Task Widget"
        Width="340"
        Height="440"
        MinWidth="300"
        MinHeight="320"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="False">
    <Border Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14">
        <Border.Effect>
            <DropShadowEffect Color="#222222" BlurRadius="18" ShadowDepth="2" Opacity="0.16" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="True" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Width="28" Height="28" Content="-" ToolTip="隠す" Click="Hide_Click" />
                    <Button Width="28" Height="28" Content="x" ToolTip="終了" Margin="6,0,0,0" Click="Exit_Click" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Tasks" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock x:Name="SummaryText" Text="0件" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,14,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TitleTextBox"
                         Height="30"
                         VerticalContentAlignment="Center"
                         MaxLength="120"
                         ToolTip="タスク名"
                         KeyDown="TitleTextBox_KeyDown" />
                <DatePicker x:Name="DueDatePicker"
                            Grid.Column="1"
                            Height="30"
                            Margin="8,0,0,0"
                            ToolTip="期限日" />
                <Button Grid.Column="2"
                        Width="42"
                        Height="30"
                        Margin="8,0,0,0"
                        Content="+"
                        ToolTip="追加"
                        Click="AddTask_Click" />
            </Grid>

            <ListBox x:Name="TasksListBox"
                     Grid.Row="2"
                     BorderThickness="0"
                     Background="Transparent"
                     ItemsSource="{Binding Tasks}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="0,7" BorderBrush="#E3E8EF" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox IsChecked="{Binding IsCompleted}"
                                          VerticalAlignment="Center"
                                          Checked="TaskCompleted_Changed"
                                          Unchecked="TaskCompleted_Changed" />
                                <StackPanel Grid.Column="1" Margin="8,0">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="14"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding DueDateText}"
                                               FontSize="11"
                                               Foreground="{Binding DueDateBrush}"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Width="28"
                                        Height="28"
                                        Content="x"
                                        ToolTip="削除"
                                        Tag="{Binding}"
                                        Click="DeleteTask_Click" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <DockPanel Grid.Row="3" Margin="0,12,0,0">
                <CheckBox x:Name="StartupCheckBox"
                          DockPanel.Dock="Left"
                          Content="Windows起動時に開始"
                          FontSize="12"
                          Checked="StartupCheckBox_Changed"
                          Unchecked="StartupCheckBox_Changed" />
                <CheckBox x:Name="ShowCompletedCheckBox"
                          DockPanel.Dock="Right"
                          Content="完了済み"
                          FontSize="12"
                          Checked="ShowCompletedCheckBox_Changed"
                          Unchecked="ShowCompletedCheckBox_Changed" />
            </DockPanel>
        </Grid>
    </Border>
</Window>

