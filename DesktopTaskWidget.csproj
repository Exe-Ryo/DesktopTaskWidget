    <TargetFramework>net48</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <LangVersion>latest</LangVersion>
    <AssemblyName>DesktopTaskWidget</AssemblyName>
    <RootNamespace>DesktopTaskWidget</RootNamespace>
